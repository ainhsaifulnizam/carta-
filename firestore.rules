rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny everything by default. Add explicit rules for future collections
    // such as events, registrations, relationships, and insights.
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can only read and write their own app-level account document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
